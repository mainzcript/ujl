# =============================================================================
# UJL Dev Demo – Environment Configuration
# =============================================================================
#
# Copy this file to .env and adjust the values as needed.
# All variables are server-only (no VITE_ prefix). The demo works with inline storage by default.
#
# =============================================================================

# -----------------------------------------------------------------------------
# Library Storage Mode
# -----------------------------------------------------------------------------
# Options:
#   - inline  (default): Library stored as Base64 in the UJLC document
#   - backend: Library stored on a Payload CMS server (services/library)
#
LIBRARY_STORAGE=inline

# -----------------------------------------------------------------------------
# Library Configuration (only needed if LIBRARY_STORAGE=backend)
# -----------------------------------------------------------------------------
#
# The token endpoint is fixed at /api/library-token (SvelteKit route).
# The API key stays server-side and is used there to issue tokens.
#
# LIBRARY_URL=http://localhost:3000
# LIBRARY_API_KEY=your-api-key-from-library-admin
